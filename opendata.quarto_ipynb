   "source": [
    "#| label: fx-scatter-chart\n",
    "#| echo: false\n",
    "fig = go.Figure()\n",
    "fig.add_trace(go.Scatter(x=fx_cross[\"fstar\"], y=fx_cross[\"idiff\"], mode=\"markers+text\", name=\"Rate differential\", text=fx_cross[\"ccy\"], textposition=\"top center\", marker={\"color\": PALETTE[\"blue_deep\"], \"size\": 8, \"opacity\": 0.88}, hovertemplate=\"%{text}<br>Dealer position: %{x:.1f}<br>Rate differential: %{y:.3f}<extra></extra>\"))\n",
    "fig.add_trace(go.Scatter(x=fx_cross[\"fstar\"], y=fx_cross[\"realized_uip_1y\"], mode=\"markers+text\", name=\"Realized UIP\", text=fx_cross[\"ccy\"], textposition=\"bottom center\", marker={\"color\": PALETTE[\"blue\"], \"size\": 8, \"opacity\": 0.72}, hovertemplate=\"%{text}<br>Dealer position: %{x:.1f}<br>Realized UIP: %{y:.3f}<extra></extra>\"))\n",
    "if not fx_survey.empty:\n",
    "    survey_plot = fx_survey.merge(fx_cross[[\"ccy\", \"fstar\"]], on=\"ccy\", how=\"left\").dropna(subset=[\"fstar\", \"value\"])\n",
    "    fig.add_trace(go.Scatter(x=survey_plot[\"fstar\"], y=survey_plot[\"value\"], mode=\"markers+text\", name=\"Survey UIP\", text=survey_plot[\"ccy\"], textposition=\"middle right\", marker={\"color\": PALETTE[\"orange\"], \"size\": 9, \"opacity\": 0.9, \"symbol\": \"diamond\"}, hovertemplate=\"%{text}<br>Dealer position: %{x:.1f}<br>Survey UIP: %{y:.3f}<extra></extra>\"))\n",
    "fig.add_hline(y=0, line_width=1, line_color=\"rgba(29,37,44,0.30)\")\n",
    "fig.add_vline(x=0, line_width=1, line_color=\"rgba(29,37,44,0.30)\")\n",
    "fig.update_layout(**base_layout(left=48), xaxis={\"title\": \"Dealer net position (% of OI)\", \"showgrid\": False, \"zeroline\": False, \"linecolor\": \"rgba(29,37,44,0.35)\"}, yaxis={\"title\": \"Average value\", \"showgrid\": False, \"zeroline\": False, \"linecolor\": \"rgba(29,37,44,0.35)\"})\n",
    "fig.show(config={\"displayModeBar\": False, \"responsive\": True})"
   ]
  },
