ite\",\"gridwidth\":2}},\"shapedefaults\":{\"line\":{\"color\":\"#2a3f5f\"}},\"annotationdefaults\":{\"arrowcolor\":\"#2a3f5f\",\"arrowhead\":0,\"arrowwidth\":1},\"geo\":{\"bgcolor\":\"white\",\"landcolor\":\"#E5ECF6\",\"subunitcolor\":\"white\",\"showland\":true,\"showlakes\":true,\"lakecolor\":\"white\"},\"title\":{\"x\":0.05},\"mapbox\":{\"style\":\"light\"},\"margin\":{\"b\":0,\"l\":0,\"r\":0,\"t\":30}}},\"shapes\":[{\"line\":{\"color\":\"rgba(29,37,44,0.30)\",\"width\":1},\"type\":\"line\",\"x0\":0,\"x1\":1,\"xref\":\"x domain\",\"y0\":0,\"y1\":0,\"yref\":\"y\"},{\"line\":{\"color\":\"rgba(29,37,44,0.30)\",\"width\":1},\"type\":\"line\",\"x0\":0,\"x1\":0,\"xref\":\"x\",\"y0\":0,\"y1\":1,\"yref\":\"y domain\"}],\"margin\":{\"l\":48,\"r\":14,\"t\":8,\"b\":72},\"font\":{\"family\":\"Segoe UI, Aptos, system-ui, sans-serif\",\"size\":11,\"color\":\"#1d252c\"},\"legend\":{\"font\":{\"size\":10},\"orientation\":\"h\",\"y\":-0.26,\"x\":0.5,\"xanchor\":\"center\",\"yanchor\":\"top\",\"bgcolor\":\"rgba(255,255,255,0)\"},\"xaxis\":{\"title\":{\"text\":\"Dealer net position (% of OI)\"},\"showgrid\":false,\"zeroline\":false,\"linecolor\":\"rgba(29,37,44,0.35)\"},\"yaxis\":{\"title\":{\"text\":\"Average value\"},\"showgrid\":false,\"zeroline\":false,\"linecolor\":\"rgba(29,37,44,0.35)\"},\"height\":285,\"paper_bgcolor\":\"rgba(0,0,0,0)\",\"plot_bgcolor\":\"rgba(255,255,255,0.56)\",\"hovermode\":\"x unified\"},                        {\"displayModeBar\": false, \"responsive\": true}                    ).then(function(){\n",
       "                            \n",
       "var gd = document.getElementById('421126f3-a4ca-42e1-849d-ca49eef37983');\n",
       "var x = new MutationObserver(function (mutations, observer) {{\n",
       "        var display = window.getComputedStyle(gd).display;\n",
       "        if (!display || display === 'none') {{\n",
       "            console.log([gd, 'removed!']);\n",
       "            Plotly.purge(gd);\n",
       "            observer.disconnect();\n",
       "        }}\n",
       "}});\n",
       "\n",
       "// Listen for the removal of the full notebook cells\n",
       "var notebookContainer = gd.closest('#notebook-container');\n",
       "if (notebookContainer) {{\n",
       "    x.observe(notebookContainer, {childList: true});\n",
       "}}\n",
       "\n",
       "// Listen for the clearing of the current output cell\n",
       "var outputEl = gd.closest('.output');\n",
       "if (outputEl) {{\n",
       "    x.observe(outputEl, {childList: true});\n",
       "}}\n",
       "\n",
