   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "setup-open-data",
   "metadata": {},
   "outputs": [],
   "source": [
    "#| label: setup-open-data\n",
    "#| echo: false\n",
    "#| output: false\n",
    "from urllib.error import URLError\n",
    "from pathlib import Path\n",
    "\n",
    "import pandas as pd\n",
    "import plotly.graph_objects as go\n",
    "\n",
    "PALETTE = {\n",
    "    \"blue_deep\": \"#00466F\",\n",
    "    \"orange\": \"#F38C10\",\n",
    "    \"blue\": \"#3297DB\",\n",
    "    \"teal\": \"#037E73\",\n",
    "    \"red\": \"#C62828\",\n",
    "    \"yellow\": \"#FEBD00\",\n",
    "    \"green\": \"#41B01E\",\n",
    "    \"coral\": \"#E84C3D\",\n",
    "    \"charcoal\": \"#3D3D3D\",\n",
    "}\n",
    "\n",
    "REPOS = {\n",
    "    \"gfc\": \"https://github.com/iweigandi/daily-global-financial-cycle-proxy\",\n",
    "    \"cip\": \"https://github.com/iweigandi/usd-chf-cip-deviations\",\n",
    "    \"gsib\": \"https://github.com/iweigandi/gsib-leverage\",\n",
    "    \"fx\": \"https://github.com/iweigandi/fx-dealer-positions\",\n",
    "}\n",
    "\n",
    "RAW = {\n",
    "    key: url.replace(\"https://github.com/\", \"https://raw.githubusercontent.com/\") + \"/main\"\n",
    "    for key, url in REPOS.items()\n",
    "}\n",
    "\n",
    "LOCAL_DATA = {\n",
    "    \"gfc\": Path(\"../gfc-proxy/data\"),\n",
    "}\n",
    "\n",
    "\n",
    "def read_public_csv(project: str, filename: str, **kwargs) -> pd.DataFrame:\n",
    "    url = f\"{RAW[project]}/data/{filename}\"\n",
    "    try:\n",
    "        return pd.read_csv(url, **kwargs)\n",
    "    except (URLError, OSError, ValueError):\n",
    "        local_dir = LOCAL_DATA.get(project)\n",
    "        if local_dir is None:\n",
    "            raise\n",
    "        return pd.read_csv(local_dir / filename, **kwargs)\n",
    "\n",
    "\n",
    "def base_layout(height=285, left=48, bottom=72):\n",
    "    return dict(\n",
    "        height=height,\n",
    "        margin={\"l\": left, \"r\": 14, \"t\": 8, \"b\": bottom},\n",
    "        paper_bgcolor=\"rgba(0,0,0,0)\",\n",
    "        plot_bgcolor=\"rgba(255,255,255,0.56)\",\n",
    "        font={\"family\": \"Segoe UI, Aptos, system-ui, sans-serif\", \"size\": 11, \"color\": \"#1d252c\"},\n",
    "        hovermode=\"x unified\",\n",
    "        legend={\"orientation\": \"h\", \"y\": -0.26, \"x\": 0.5, \"xanchor\": \"center\", \"yanchor\": \"top\", \"bgcolor\": \"rgba(255,255,255,0)\", \"font\": {\"size\": 10}},\n",
    "    )\n",
    "\n",
    "\n",
    "gfc_daily = read_public_csv(\"gfc\", \"gfc_proxy_daily.csv\", index_col=0, parse_dates=True).rename(columns={\"GFC Proxy-Daily\": \"Daily proxy\"})\n",
    "gfc_monthly = read_public_csv(\"gfc\", \"gfc_proxies_monthly.csv\", index_col=0, parse_dates=True).rename(columns={\"GFC Proxy-Monthly\": \"Monthly proxy\"})\n",
    "cip = read_public_csv(\"cip\", \"usd_chf_cip_deviations_monthly.csv\", parse_dates=[\"Date\"])\n",
    "gsib = read_public_csv(\"gsib\", \"gsib_market_leverage.csv\", parse_dates=[\"date\"])\n",
    "fx_panel = read_public_csv(\"fx\", \"panel_data.csv\", parse_dates=[\"date\"])\n",
    "fx_cross = read_public_csv(\"fx\", \"cross_section_means.csv\")\n",
    "fx_bcb = read_public_csv(\"fx\", \"bcb_focus_brl_usd_expectations.csv\", parse_dates=[\"survey_date\"])\n",
    "fx_ecb = read_public_csv(\"fx\", \"ecb_spf_eur_usd_expectations.csv\", parse_dates=[\"survey_date\"])\n",
    "\n",
    "\n",
    "def survey_uip_points(panel, bcb, ecb):\n",
    "    rows = []\n",
    "    if \"EUR\" in set(panel[\"ccy\"]):\n",
    "        exp = ecb[ecb[\"horizon_years_approx\"].round().eq(1)].dropna(subset=[\"expected_log_change_eur_per_usd\"])\n",
    "        if not exp.empty:\n",
    "            exp = exp.sort_values([\"survey_date\", \"target_year\"]).groupby(\"survey_date\").tail(1)\n",
    "            exp = exp.set_index(\"survey_date\")[\"expected_log_change_eur_per_usd\"].resample(\"ME\").last()\n",
    "            eur = panel[panel[\"ccy\"].eq(\"EUR\")].set_index(\"date\").join(exp.rename(\"expected_change\"), how=\"left\")\n",
    "            value = (eur[\"idiff\"] - eur[\"expected_change\"]).dropna().mean()\n",
    "            if pd.notna(value):\n",
    "                rows.append({\"ccy\": \"EUR\", \"value\": value})\n",
    "    if \"BRL\" in set(panel[\"ccy\"]):\n",
    "        exp = bcb[bcb[\"horizon_years_approx\"].round().eq(1)].dropna(subset=[\"expected_log_change_brl_per_usd\"])\n",
    "        if not exp.empty:\n",
    "            exp = exp.sort_values([\"survey_date\", \"target_year\"]).groupby(\"survey_date\").tail(1)\n",
    "            exp = exp.set_index(\"survey_date\")[\"expected_log_change_brl_per_usd\"].resample(\"ME\").last()\n",
    "            brl = panel[panel[\"ccy\"].eq(\"BRL\")].set_index(\"date\").join(exp.rename(\"expected_change\"), how=\"left\")\n",
    "            value = (brl[\"idiff\"] - brl[\"expected_change\"]).dropna().mean()\n",
    "            if pd.notna(value):\n",
    "                rows.append({\"ccy\": \"BRL\", \"value\": value})\n",
    "    return pd.DataFrame(rows)\n",
    "\n",
    "fx_survey = survey_uip_points(fx_panel, fx_bcb, fx_ecb)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "40c48433",
   "metadata": {},
   "source": [
    "::: {.open-data-page .open-data-compact}\n",
    "::: {.chart-grid}\n",
    "::: {.chart-card .chart-card-main}\n",
    "::: {.lang-en}\n",
    "#### Daily Global Financial Cycle proxy\n",
    "\n",
    "::: {.chart-card-text}\n",
    "Following Habib & Venditti (2019), the proxy is the first principal component of national and sectoral equity-market index returns.\n",
    "\n",
    "$$r_{j,t} = \\lambda_j f_t^{\\mathrm{global}} + \\xi_{j,t}$$\n",
    "\n",
    "[Repository](https://github.com/iweigandi/daily-global-financial-cycle-proxy)\n",
    ":::\n",
    ":::\n",
    "::: {.lang-es}\n",
    "#### Proxy diario del Ciclo Financiero Global\n",
    "\n",
    "::: {.chart-card-text}\n",
    "Siguiendo a Habib y Venditti (2019), el proxy es el primer componente principal de los retornos de índices del mercado de capitales nacionales y sectoriales.\n",
    "\n",
    "$$r_{j,t} = \\lambda_j f_t^{\\mathrm{global}} + \\xi_{j,t}$$\n",
    "\n",
    "[Repositorio](https://github.com/iweigandi/daily-global-financial-cycle-proxy)\n",
    ":::\n",
    ":::"
   ]
  },
  {
